{
  "name": "knockknock-prof",
  "version": "0.1.0",
  "description": "Group consultation scheduling app for Wits students and lecturers",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "build": "npm install && npm run setup",
    "setup": "node database/setup.js",
    "test": "jest --coverage",
    "test:e2e": "playwright test"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ],
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "nodemailer": "^8.0.7"
  }
}
