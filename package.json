{
  "name": "knockknock-prof",
  "version": "0.1.0",
  "description": "Group consultation scheduling app for Wits students and lecturers",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "build": "npm install && npm rebuild sqlite3 better-sqlite3 --build-from-source && npm run setup",
    "setup": "node database/setup.js",
    "test": "jest --coverage",
    "test:e2e": "playwright test"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "connect-session-sequelize": "^8.0.6",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1"
  }
}